API_KEY=replace-with-strong-random-key-soc

# SOC demo instance: dashboard enabled and internal-only.
ENABLE_DASHBOARD=true
DASHBOARD_INTERNAL_ONLY=true
DASHBOARD_ADMIN_KEY=replace-with-very-strong-admin-key

# Optional: keep banking API enabled unless SOC scope says otherwise.
ENABLE_BANKING_API=true

# Strict sandbox mode: disallow local fallback.
SANDBOX_ISOLATION_LEVEL=2
