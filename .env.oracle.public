API_KEY=ms_dev_8e7f2c1b9a4d5e3f6c2b1a7d4f5e6c3b

# PostgreSQL (Banking API real mode).
DATABASE_URL=postgresql+psycopg2://mirage_user:mirage_password@postgres:5432/mirage_sentinel

# Public demo instance: normal/attack flow only, no dashboard exposure.
ENABLE_DASHBOARD=false
DASHBOARD_INTERNAL_ONLY=true
DASHBOARD_ADMIN_KEY=

# Optional: keep banking API enabled unless you need a narrower surface.
ENABLE_BANKING_API=true

# Strict sandbox mode: disallow local fallback.
SANDBOX_ISOLATION_LEVEL=2

# Mirage LLM (Ollama) configuration
MIRAGE_USE_LLM=true
MIRAGE_LLM_PROVIDER=ollama

# 使用 Docker 預設的 Bridge IP，讓 Compose 內的後端能連到外部的 Ollama 容器
MIRAGE_OLLAMA_URL=http://172.17.0.1:11434

# 必須與剛才下載的完整路徑完全一致
MIRAGE_OLLAMA_MODEL=hf.co/fdtn-ai/Foundation-Sec-1.1-8B-Instruct-Q4_K_M-GGUF
