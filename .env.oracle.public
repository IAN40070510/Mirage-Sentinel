API_KEY=replace-with-strong-random-key-public

# PostgreSQL (Banking API real mode). Leave blank to stay in Demo mode.
DATABASE_URL=

# Public demo instance: normal/attack flow only, no dashboard exposure.
ENABLE_DASHBOARD=false
DASHBOARD_INTERNAL_ONLY=true
DASHBOARD_ADMIN_KEY=

# Optional: keep banking API enabled unless you need a narrower surface.
ENABLE_BANKING_API=true

# Strict sandbox mode: disallow local fallback.
SANDBOX_ISOLATION_LEVEL=2
